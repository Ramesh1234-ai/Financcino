# ============================================
# Environment Variables for BrokTok Frontend
# ============================================
# Copy this file to .env or .env.local and fill in your values
# This file should be committed to the repository as reference

# Backend API URL
# Development: http://localhost:3000/api
# Production: Your production backend URL
VITE_API_URL=http://localhost:3000/api

# Clerk Authentication 
# Get your publishable key from https://dashboard.clerk.com
# Click on "API Keys" in the left sidebar
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ============================================
# Build-time Configuration
# ============================================
# For production builds, set these via environment or CI/CD pipeline:
# export VITE_API_URL=https://api.yourproduction.com/api
# export VITE_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_KEY
# npm run build
