# Example environment variables - Copy this to .env and fill in values
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/kharcha-core
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
